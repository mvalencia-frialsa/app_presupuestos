        <button onclick="closeProjectModal()" class="rounded-2xl border border-slate-200 px-4 py-2.5 text-sm font-semibold hover:bg-slate-50">Cancelar</button>
        <button onclick="closeProjectModal(); showToast('success','Proyecto registrado','El presupuesto quedó marcado como proyecto.')" class="rounded-2xl bg-olive-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-olive-700">Guardar proyecto</button>
      </div>
    </div>
  </div>

  <!-- BUDGET DETAIL MODAL -->
  <div id="budgetDetailModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-navy-900/55 p-4">
    <div class="max-h-[92vh] w-full max-w-4xl overflow-y-auto rounded-[2rem] bg-white p-6 shadow-soft">
      <div class="mb-6 flex items-start justify-between gap-4">
        <div>
          <h3 class="text-2xl font-semibold text-navy-900">Presupuesto PRE-0023</h3>
          <p class="mt-1 text-sm text-slate-500">Vista solo lectura por estado aprobado.</p>
        </div>
        <button onclick="closeBudgetDetail()" class="rounded-2xl border border-slate-200 px-3 py-2 text-slate-500 hover:bg-slate-50">✕</button>
      </div>

      <div class="grid grid-cols-1 gap-5 md:grid-cols-2">
        <div class="rounded-3xl border border-slate-200 p-5">
          <h4 class="font-semibold text-navy-900">Información general</h4>
          <dl class="mt-4 space-y-3 text-sm">
            <div class="flex justify-between gap-4"><dt class="text-slate-500">Área</dt><dd class="font-semibold">Operaciones</dd></div>
            <div class="flex justify-between gap-4"><dt class="text-slate-500">Concepto</dt><dd class="font-semibold">Monitoreo cámaras</dd></div>
            <div class="flex justify-between gap-4"><dt class="text-slate-500">Monto</dt><dd class="font-semibold">$520,000</dd></div>
            <div class="flex justify-between gap-4"><dt class="text-slate-500">Estado</dt><dd><span class="rounded-full bg-green-50 px-3 py-1 text-xs font-semibold text-green-700">Aprobado</span></dd></div>
          </dl>
        </div>

        <div class="rounded-3xl border border-slate-200 p-5">
          <h4 class="font-semibold text-navy-900">Ticket Mesa de Ayuda</h4>
          <dl class="mt-4 space-y-3 text-sm">
            <div class="flex justify-between gap-4"><dt class="text-slate-500">Ticket</dt><dd class="font-semibold">HD-88921</dd></div>
            <div class="flex justify-between gap-4"><dt class="text-slate-500">Estado</dt><dd class="font-semibold text-blue-700">Abierto</dd></div>
            <div class="flex justify-between gap-4"><dt class="text-slate-500">Fecha</dt><dd class="font-semibold">07/07/2026</dd></div>
          </dl>
          <button onclick="showToast('info','Mesa de Ayuda','Apertura simulada del ticket HD-88921.')" class="mt-5 rounded-2xl border border-slate-200 px-4 py-2 text-sm font-semibold hover:bg-slate-50">Ver ticket</button>
        </div>

        <div class="rounded-3xl border border-slate-200 p-5 md:col-span-2">
          <h4 class="font-semibold text-navy-900">Proyecto asociado</h4>
          <div class="mt-4 grid grid-cols-1 gap-4 text-sm md:grid-cols-4">
            <div class="rounded-2xl bg-slate-50 p-4"><p class="text-slate-500">Valor estimado</p><p class="font-semibold">$520,000</p></div>
            <div class="rounded-2xl bg-slate-50 p-4"><p class="text-slate-500">Valor real</p><p class="font-semibold">$430,000</p></div>
            <div class="rounded-2xl bg-slate-50 p-4"><p class="text-slate-500">Hardware</p><p class="font-semibold">$230,000</p></div>
            <div class="rounded-2xl bg-slate-50 p-4"><p class="text-slate-500">Software</p><p class="font-semibold">$210,000</p></div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    const pageTitles = {
      dashboardPage: 'Panel principal',
      budgetsPage: 'Mis presupuestos',
      capturePage: 'Nuevo presupuesto',
      bulkPage: 'Carga masiva',
      approvalPage: 'Aprobaciones',
      adminPage: 'Administración'
    };

    function enterApp() {
      document.getElementById('loginScreen').classList.add('hidden');
      document.getElementById('appShell').classList.remove('hidden');
      showToast('success', 'Bienvenido', 'Accediste al panel principal del mockup.');
    }

    function logout() {
      document.getElementById('appShell').classList.add('hidden');
      document.getElementById('loginScreen').classList.remove('hidden');
      document.getElementById('profileMenu').classList.add('hidden');
    }

    function showPage(pageId) {
      document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
      document.getElementById(pageId).classList.add('active');
      document.getElementById('pageTitle').textContent = pageTitles[pageId] || 'Panel';

      document.querySelectorAll('.nav-link').forEach(btn => {
        btn.classList.remove('nav-active', 'bg-navy-900', 'text-white');
      });

      document.querySelectorAll(`.nav-link[data-page="${pageId}"]`).forEach(btn => {
        btn.classList.add('nav-active');
      });

      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    document.addEventListener('click', (event) => {
      const nav = event.target.closest('.nav-link');
      if (nav?.dataset.page) showPage(nav.dataset.page);

      const tab = event.target.closest('.admin-tab');
      if (tab?.dataset.tab) showAdminTab(tab.dataset.tab, tab);
    });

    function showAdminTab(tabId, activeButton) {
      document.querySelectorAll('.admin-tab-panel').forEach(panel => panel.classList.remove('active'));
      document.getElementById(tabId).classList.add('active');

      document.querySelectorAll('.admin-tab').forEach(btn => {
        btn.className = 'admin-tab rounded-2xl px-4 py-2.5 text-sm font-semibold text-slate-600 hover:bg-slate-50';
      });
      activeButton.className = 'admin-tab rounded-2xl bg-navy-900 px-4 py-2.5 text-sm font-semibold text-white';
    }

    function toggleProfile() {
      document.getElementById('profileMenu').classList.toggle('hidden');
    }

    function openProjectModal() {
      const modal = document.getElementById('projectModal');
      modal.classList.remove('hidden');
      modal.classList.add('flex');
    }

    function closeProjectModal() {
      const modal = document.getElementById('projectModal');
      modal.classList.add('hidden');
      modal.classList.remove('flex');
    }

    function openBudgetDetail() {
      const modal = document.getElementById('budgetDetailModal');
      modal.classList.remove('hidden');
      modal.classList.add('flex');
    }

    function closeBudgetDetail() {
      const modal = document.getElementById('budgetDetailModal');
      modal.classList.add('hidden');
      modal.classList.remove('flex');
    }

    function validateBulk() {
      document.getElementById('bulkResults').classList.remove('hidden');
      showToast('error', 'Validación con errores', 'Se encontraron 8 registros con errores por fila y columna.');
    }

    function selectApproval(folio, project) {
      document.getElementById('approvalFolio').textContent = folio;
      document.getElementById('approvalProject').textContent = project ? 'Sí' : 'No';
      showToast('info', 'Presupuesto seleccionado', `${folio} cargado para revisión.`);
    }

    function showToast(type, title, message) {
      const palette = {
        info: 'border-blue-200 bg-blue-50 text-blue-800',
        success: 'border-green-200 bg-green-50 text-green-800',
        error: 'border-red-200 bg-red-50 text-red-800',
        warning: 'border-yellow-200 bg-yellow-50 text-yellow-800'
      };

      const dots = {
        info: 'bg-blue-500',
        success: 'bg-green-500',
        error: 'bg-red-500',
        warning: 'bg-yellow-500'
      };

      const toast = document.createElement('div');
      toast.className = `rounded-2xl border p-4 shadow-soft ${palette[type] || palette.info}`;
      toast.innerHTML = `
        <div class="flex gap-3">
          <span class="mt-1 h-2.5 w-2.5 shrink-0 rounded-full ${dots[type] || dots.info}"></span>
          <div class="min-w-0">
            <p class="font-semibold">${title}</p>
            <p class="mt-1 text-sm opacity-80">${message}</p>
          </div>
          <button class="ml-auto opacity-60 hover:opacity-100" onclick="this.closest('div.rounded-2xl').remove()">✕</button>
        </div>
      `;

      document.getElementById('toastContainer').appendChild(toast);
      setTimeout(() => toast.remove(), 5200);
    }
  </script>
</body>
</html>
